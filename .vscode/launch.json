{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to QEMU on host OS",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "x86_64",
            "program": "${workspaceRoot}/main64/kernel/target/x86_64-unknown-none/debug/kaos_kernel",
            "miDebuggerServerAddress": "host.docker.internal:12345",
            "miDebuggerPath": "/usr/bin/gdb",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Set architecture to x64",
                    "text": "set architecture i386:x86-64",
                    "ignoreFailures": false
                },
                {
                    "description": "Enable disassembly flavor",
                    "text": "set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Load Rust kernel symbols at virtual address",
                    "text": "-interpreter-exec console \"add-symbol-file ${workspaceRoot}/main64/kernel/target/x86_64-unknown-none/debug/kaos_kernel 0xFFFF800000100000\""
                },
                {
                    "description": "Load FILEDEMO user program symbols at virtual address",
                    "text": "-interpreter-exec console \"add-symbol-file ${workspaceRoot}/main64/user_programs/filedemo/target/x86_64-unknown-none/debug/filedemo 0x0000700000000000\""
                }
            ],
            "cwd": "${workspaceRoot}"
        },
        {
            "name": "Debug KAOS Rust x64 locally",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/main64/kernel/target/x86_64-unknown-none/debug/kaos_kernel",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "miDebuggerPath": "rust-gdb",
            "miDebuggerServerAddress": "localhost:12345",
            "preLaunchTask": "Build & Run KAOS Rust",
            "stopAtEntry": true,
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Set architecture to x64",
                    "text": "set architecture i386:x86-64",
                    "ignoreFailures": false
                },
                {
                    "description": "Enable flex/layout settings",
                    "text": "set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Load Rust kernel symbols at virtual address",
                    "text": "-interpreter-exec console \"add-symbol-file ${workspaceFolder}/main64/kernel/target/x86_64-unknown-none/debug/kaos_kernel 0xFFFF800000100000\""
                },
                {
                    "description": "Load FILEDEMO user program symbols at virtual address",
                    "text": "-interpreter-exec console \"add-symbol-file ${workspaceFolder}/main64/user_programs/filedemo/target/x86_64-unknown-none/debug/filedemo 0x0000700000000000\""
                }
            ]
        }
    ]
}
